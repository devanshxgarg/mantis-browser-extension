{
  "name": "mantis-extension",
  "displayName": "Mantis",
  "version": "1.0.0",
  "description": "A minimal Bloomberg-style market dashboard for Chrome.",
  "author": "Mantis",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "plasmo package",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@plasmohq/storage": "^1.15.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.18.2",
    "lucide-react": "^0.468.0",
    "plasmo": "^0.90.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.10.2",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  },
  "manifest": {
    "manifest_version": 3,
    "name": "Mantis",
    "short_name": "Mantis",
    "description": "Fast market awareness in a minimal Bloomberg-style dashboard.",
    "version": "1.0.0",
    "permissions": [
      "storage"
    ],
    "host_permissions": [
      "https://query1.finance.yahoo.com/*",
      "https://feeds.finance.yahoo.com/*"
    ]
  }
}
